<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1744" />
        </shape>
    </item>

    <item>
        <inset
            android:insetLeft="92dp"
            android:insetTop="220dp"
            android:insetRight="92dp"
            android:insetBottom="220dp">
            <bitmap
                android:antialias="true"
                android:filter="true"
                android:gravity="center"
                android:src="@drawable/geomove_logo" />
        </inset>
    </item>
</layer-list>
